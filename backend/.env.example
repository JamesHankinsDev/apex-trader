# Trading gate — set to 'true' in production only (blocks all orders when false)
TRADING_ENABLED=false

# Alpaca API Credentials
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# paper | live
ALPACA_MODE=paper

# Bot Settings (can be overridden via API)
POSITION_SIZE=0.80
STOP_LOSS=0.08
TAKE_PROFIT=0.25
RSI_BUY_BELOW=35
RSI_SELL_ABOVE=70
SCAN_INTERVAL_SECONDS=60

# Watchlist (comma-separated Alpaca crypto symbols)
WATCHLIST=BTC/USD,ETH/USD,SOL/USD,DOGE/USD,AVAX/USD
# Bear Market Watchlist — used when BTC is below 50-day SMA (defaults to bull watchlist if not set)
WATCHLIST_BEAR=BTC/USD,ETH/USD,SOL/USD

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000
