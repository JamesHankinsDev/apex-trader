# ─── MASTER KILL SWITCH ────────────────────────────────────────
# Set to 'true' in production only — blocks ALL live Alpaca orders when false
TRADING_ENABLED=false

# ─── Alpaca API Credentials (Main Bot) ─────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# paper | live
ALPACA_MODE=paper

# ─── Main Bot Settings ────────────────────────────────────────
POSITION_SIZE=0.80
STOP_LOSS=0.08
TAKE_PROFIT=0.25
RSI_BUY_BELOW=35
RSI_SELL_ABOVE=70
SCAN_INTERVAL_SECONDS=30

# Watchlist (comma-separated Alpaca crypto symbols)
WATCHLIST=BTC/USD,ETH/USD,SOL/USD,DOGE/USD,AVAX/USD
# Bear Market Watchlist — used when BTC is below 50-day SMA (defaults to bull watchlist if not set)
WATCHLIST_BEAR=BTC/USD,ETH/USD,SOL/USD

# ─── Scalp Settings (shared across all bots) ──────────────────
# USD per scalp position (BTC bear scalps use half this value)
SCALP_TRADE_SIZE=25
# Minimum buying power required before a scalp entry is allowed
MIN_SCALP_BALANCE=30

# ─── Experiment 1 (Mean Reversion / 1-Min Scalp) ─────────────
EXPERIMENT_1_ALPACA_API_KEY=your_exp1_api_key
EXPERIMENT_1_ALPACA_SECRET_KEY=your_exp1_secret_key
EXPERIMENT_1_WATCHLIST=BTC/USD,ETH/USD,SOL/USD
EXPERIMENT_1_MAX_POSITIONS=2
EXPERIMENT_1_SCAN_INTERVAL_SECONDS=30

# ─── Experiment 2 (Momentum Breakout / BTC DCA) ──────────────
EXPERIMENT_2_ALPACA_API_KEY=your_exp2_api_key
EXPERIMENT_2_ALPACA_SECRET_KEY=your_exp2_secret_key
EXPERIMENT_2_WATCHLIST=AVAX/USD,LINK/USD,AAVE/USD,DOT/USD,UNI/USD
EXPERIMENT_2_SCAN_INTERVAL_SECONDS=30

# ─── Server ───────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
