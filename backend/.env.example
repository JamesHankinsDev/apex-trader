# ─── Infrastructure ────────────────────────────────────────────
# Master kill switch — set to 'true' in production to enable live orders
TRADING_ENABLED=false
# Comma-separated CORS origins (production + local dev)
FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000

# ─── Alpaca API Credentials ───────────────────────────────────
# Main Bot
ALPACA_API_KEY=your_api_key
ALPACA_SECRET_KEY=your_secret_key
ALPACA_MODE=paper

# Experiment 1
EXPERIMENT_1_ALPACA_API_KEY=your_exp1_api_key
EXPERIMENT_1_ALPACA_SECRET_KEY=your_exp1_secret_key

# Experiment 2
EXPERIMENT_2_ALPACA_API_KEY=your_exp2_api_key
EXPERIMENT_2_ALPACA_SECRET_KEY=your_exp2_secret_key

# ─── Watchlists ───────────────────────────────────────────────
WATCHLIST=BTC/USD,ETH/USD,SOL/USD,AVAX/USD,LINK/USD
WATCHLIST_BEAR=BTC/USD,ETH/USD,SOL/USD
EXPERIMENT_1_WATCHLIST=BTC/USD,ETH/USD,SOL/USD
EXPERIMENT_1_WATCHLIST_BEAR=BTC/USD,ETH/USD,SOL/USD
EXPERIMENT_2_WATCHLIST=AVAX/USD,LINK/USD,AAVE/USD,DOT/USD,UNI/USD
EXPERIMENT_2_WATCHLIST_BEAR=BTC/USD

# ─── Live Trader (mirrors winning experiment) ─────────────────
# Set LIVE_TRADER_ENABLED=true to activate. Uses separate Alpaca account.
LIVE_TRADER_ENABLED=false
LIVE_TRADER_API_KEY=your_live_api_key
LIVE_TRADER_SECRET_KEY=your_live_secret_key
LIVE_TRADER_MODE=paper

# All strategy parameters, position sizing, risk limits, and
# scan intervals are now configured in code (version controlled).
# See: bot.js, experiment-bot.js, experiment2-bot.js, positionSizer.js
