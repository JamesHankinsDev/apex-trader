# ─── Infrastructure ────────────────────────────────────────────
# Master kill switch — blocks ALL Alpaca orders when false
TRADING_ENABLED=false
# Comma-separated CORS origins
FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000

# ─── Experiment 1 (Momentum) — paper trading ─────────────────
EXP1_ALPACA_API_KEY=your_exp1_key
EXP1_ALPACA_SECRET_KEY=your_exp1_secret
EXP1_WATCHLIST=BTC/USD,ETH/USD,SOL/USD,AVAX/USD,LINK/USD
EXP1_WATCHLIST_BEAR=BTC/USD,ETH/USD,SOL/USD

# ─── Experiment 2 (Scalping) — paper trading ─────────────────
EXP2_ALPACA_API_KEY=your_exp2_key
EXP2_ALPACA_SECRET_KEY=your_exp2_secret
EXP2_WATCHLIST=BTC/USD,ETH/USD,SOL/USD
EXP2_WATCHLIST_BEAR=BTC/USD,ETH/USD,SOL/USD

# ─── Experiment 3 (Breakout) — paper trading ─────────────────
EXP3_ALPACA_API_KEY=your_exp3_key
EXP3_ALPACA_SECRET_KEY=your_exp3_secret
EXP3_WATCHLIST=AVAX/USD,LINK/USD,AAVE/USD,DOT/USD,UNI/USD
EXP3_WATCHLIST_BEAR=BTC/USD

# ─── Live Trader (mirrors winning experiment) — REAL MONEY ───
# Only enable when experiments have 50+ trades and a clear winner
LIVE_TRADER_ENABLED=false
LIVE_TRADER_API_KEY=your_live_key
LIVE_TRADER_SECRET_KEY=your_live_secret

# All experiments paper trade automatically.
# The live trader uses real money — only its trades hit the live API.
# Strategy parameters are configured in code, not env vars.
